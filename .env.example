# DB configurations
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=spoticode

# JWT Configurations
JWT_SECRET="Gd34@$39@$%932a"
REFRESH_TOKEN_SECRET="Ha34@$32!$%932a"

# Server Configurations
APP_PORT=3000
BASE_URL=localhost:3000/api
SUPER_ADMIN_PASSWORD=123456
ORIGIN = localhost:3000

# Kavenegar OTP Configurations
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_SENDER=
OTP_SECRET=replace_with_strong_random_secret

# Redis Configurations
REDIS_ENABLED=true
REDIS_URL="redis://localhost:6379"

# Elasticsearch Configurations
ELASTICSEARCH_USERS_INDEX=users_index
ELASTICSEARCH_NODE=http://localhost:9200

# Static Asset Configurations
STATIC_ASSET_PATH="../../../uploads"

# Postgres Container Environment Variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spoticode

#Authorized Origins
AUTHORIZED_ORIGINS="*"

#Translation language
I18N_FALLBACK_LANGUAGE='fa'

#Locale
LOCALE='fa-ir'
TIME_ZONE=iran

# ZarinPal Gateway
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:5000/api/orders/gateway/zarinpal/callback
ZARINPAL_CURRENCY=IRR
ZARINPAL_AUTO_VERIFY=false
ZARINPAL_TIMEOUT_MS=15000
ORDER_TTL_MINUTES=30
