{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^@common/(.*)$": "<rootDir>/../src/common/$1",
    "^@app/(.*)$": "<rootDir>/../src/application/$1",
    "^@auth/(.*)$": "<rootDir>/../src/common/auth/$1",
    "^@config/(.*)$": "<rootDir>/../src/config/config/$1",
    "@custom/(.*)$": ["<rootDir>/custom_modules/$1"]
  }
}
