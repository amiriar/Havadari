# DB configurations
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=spoticode

# JWT Configurations
JWT_SECRET="Gd34@$39@$%932a"
REFRESH_TOKEN_SECRET="Ha34@$32!$%932a"

# Server Configurations
APP_PORT=3000
BASE_URL=localhost:3000/api
SUPER_ADMIN_PASSWORD=123456
ORIGIN = localhost:3000

# Kavenegar OTP Configurations
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_SENDER=
OTP_SECRET=replace_with_strong_random_secret

# Match Sync Providers
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
API_FOOTBALL_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1

# Redis Configurations
REDIS_ENABLED=true
REDIS_URL="redis://redis:6379"

# Elasticsearch Configurations
ELASTICSEARCH_USERS_INDEX=users_index
ELASTICSEARCH_NODE=http://elasticsearch:9200

# Static Asset Configurations
STATIC_ASSET_PATH="../../../uploads"

# Postgres Container Environment Variables
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=spoticode

#Authorized Origins
AUTHORIZED_ORIGINS="*"

#Translation language
I18N_FALLBACK_LANGUAGE='fa'

#Locale
LOCALE='fa-ir'
TIME_ZONE=iran
