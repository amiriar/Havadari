{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "dtoFileNameSuffix": [".dto.ts", ".enum.ts", ".response.dto.ts"],
          "introspectComments": true
        }
      }
    ],
    "assets": [{ "include": "i18n/**/*", "watchAssets": true }]
  }
}
